<view class="container">
  <view class="header">
    <text class="title">📱 扫码帮手</text>
    <button 
      class="scan-btn"
      bindtap="scanQRCode"
      loading="{{loading}}"
    >
      扫描二维码
    </button>
  </view>

  <!-- 最近扫描 -->
  <block wx:if="{{recentScans.length > 0}}">
    <view class="section">
      <text class="section-title">最近扫描</text>
      <view class="recent-scans">
        <block wx:for="{{recentScans}}" wx:key="index">
          <view 
            class="recent-item"
            data-value="{{item}}"
            bindtap="quickScan"
          >
            <text class="recent-text">{{item}}</text>
            <image src="/images/arrow-right.png" mode="aspectFit" />
          </view>
        </block>
      </view>
    </view>
  </block>

  <view class="section">
    <view class="section-header">
      <text class="section-title">扫码记录</text>
      <button 
        class="clear-btn"
        size="mini"
        bindtap="clearAllHistory"
        wx:if="{{scanHistory.length > 0}}"
      >
        清空
      </button>
    </view>
    
    <block wx:if="{{scanHistory.length > 0}}">
      <view class="history-list">
        <view class="history-item" wx:for="{{scanHistory}}" wx:key="id">
          <view class="item-content">
            <text class="qr-value">{{item.qr_value}}</text>
            <text class="scan-time">{{item.scanned_date}}</text>
          </view>
          
          <view class="item-actions">
            <button 
              size="mini"
              data-id="{{item.id}}"
              bindtap="viewDetail"
            >
              查看
            </button>
            <button 
              size="mini"
              class="delete-btn"
              data-id="{{item.id}}"
              bindtap="deleteScan"
            >
              删除
            </button>
          </view>
        </view>
      </view>
    </block>
    
    <view class="empty-state" wx:else>
      <image src="/images/qr-empty.png" mode="aspectFit" />
      <text class="empty-text">暂无扫码记录</text>
      <text class="empty-desc">点击下方按钮开始扫描</text>
    </view>
  </view>

  <!-- 扫码结果确认弹窗 -->
  <block wx:if="{{showResultModal}}">
    <view class="modal-mask" bindtap="cancelRecord"></view>
    <view class="result-modal">
      <view class="modal-header">
        <text class="modal-title">扫码结果</text>
        <text class="close-btn" bindtap="cancelRecord">✕</text>
      </view>
      
      <view class="modal-body">
        <text class="scan-result">{{currentScan}}</text>
        <view class="scan-info">
          <text>时间：{{formatCurrentTime()}}</text>
          <text>类型：{{detectQRType(currentScan)}}</text>
        </view>
      </view>
      
      <view class="modal-footer">
        <button 
          class="cancel-modal-btn"
          bindtap="cancelRecord"
        >
          取消
        </button>
        <button 
          class="confirm-modal-btn"
          bindtap="confirmRecord"
        >
          确认记录
        </button>
      </view>
    </view>
  </block>
</view>