.container{padding:20px}
.header{margin-bottom:20px}
.title{font-size:24px;font-weight:bold}
.subtitle{font-size:14px;color:#666;display:block;margin-top:5px}
.week-info{margin-bottom:20px}
.week-info progress{width:100%}
.item{padding:15px;background:#f5f5f5;margin-bottom:10px;border-radius:8px;display:flex;align-items:center}
.item.done{background:#e8f5e9}
.checkbox{width:24px;height:24px;border:2px solid #ddd;border-radius:50%;margin-right:15px;display:flex;align-items:center;justify-content:center;font-size:16px}
.item.done .checkbox{background:#4CAF50;border-color:#4CAF50;color:white}
.info{flex:1}
.info text{display:block}
.cat{font-size:12px;color:#999;margin-top:5px}
.actions{display:flex;gap:10px;margin-top:30px}
.actions button{flex:1}