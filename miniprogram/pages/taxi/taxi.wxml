<view class="container">
  <view class="header">
    <text class="title">🚗 叫车帮手</text>
    <button 
      class="submit-btn"
      bindtap="submitRequest"
      loading="{{submitting}}"
    >
      我要叫车
    </button>
  </view>

  <!-- 统计卡片 -->
  <view class="stats-section">
    <view class="stat-card">
      <text class="stat-number">{{todayRequests}}</text>
      <text class="stat-label">今日叫车</text>
    </view>
    <view class="stat-card">
      <text class="stat-number">{{pendingRequests}}</text>
      <text class="stat-label">待分配</text>
    </view>
    <view class="stat-card">
      <text class="stat-number">{{completedRequests}}</text>
      <text class="stat-label">已完成</text>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">叫车记录</text>
      <button 
        class="refresh-btn"
        size="mini"
        bindtap="refreshList"
        wx:if="{{!loading}}"
      >
        刷新
      </button>
    </view>
    
    <block wx:if="{{requests.length > 0}}">
      <view class="request-list">
        <view class="request-item" wx:for="{{requests}}" wx:key="id">
          <view class="item-header">
            <text class="destination">{{item.destination}}</text>
            <text class="status {{item.status}}">{{getStatusText(item.status)}}</text>
          </view>
          
          <view class="item-content">
            <text class="time">{{formatTime(item.scheduled_time)}}</text>
            <text class="notes">{{item.notes || '无备注'}}</text>
          </view>
          
          <view class="item-actions">
            <block wx:if="{{item.status === 'pending'}}">
              <button 
                size="mini"
                data-id="{{item.id}}"
                data-destination="{{item.destination}}"
                bindtap="cancelRequest"
              >
                取消
              </button>
              <button 
                size="mini"
                data-request-id="{{item.id}}"
                bindtap="viewDriverInfo"
              >
                司机信息
              </button>
            </block>
            
            <block wx:elif="{{item.status === 'assigned'}}">
              <button 
                size="mini"
                data-id="{{item.id}}"
                data-destination="{{item.destination}}"
                bindtap="viewDetail"
              >
                查看详情
              </button>
              <button 
                size="mini"
                data-request-id="{{item.id}}"
                bindtap="viewDriverInfo"
              >
                司机信息
              </button>
            </block>
            
            <block wx:else>
              <button 
                size="mini"
                data-id="{{item.id}}"
                data-destination="{{item.destination}}"
                bindtap="reorderRequest"
              >
                再次叫车
              </button>
              <button 
                size="mini"
                data-id="{{item.id}}"
                bindtap="viewDetail"
              >
                查看
              </button>
            </block>
          </view>
        </view>
      </view>
    </block>
    
    <view class="empty-state" wx:else>
      <image src="/images/taxi-empty.png" mode="aspectFit" />
      <text class="empty-text">暂无叫车记录</text>
      <text class="empty-desc">点击下方按钮发起叫车</text>
    </view>
  </view>
</view>