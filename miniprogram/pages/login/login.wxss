/* pages/login/login.wxss */
.container {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1F2937;
  display: block;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #6B7280;
}

.role-selection {
  display: flex;
  gap: 24rpx;
  margin-bottom: 60rpx;
}

.role-card {
  flex: 1;
  border: 2rpx solid #E5E7EB;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  text-align: center;
  background-color: #FFFFFF;
  transition: all 0.2s ease;
}

.role-card.selected {
  border-color: #10B981;
  background-color: #F0FAF6;
}

.role-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2937;
  margin-top: 16rpx;
  margin-bottom: 8rpx;
}

.role-desc {
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.4;
}

.privacy-section {
  display: flex;
  align-items: flex-start;
  margin-bottom: 40rpx;
  padding: 0 12rpx;
}

checkbox {
  margin-right: 12rpx;
  transform: scale(0.9);
}

.privacy-text {
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.6;
  flex: 1;
}

.link {
  color: #10B981;
  text-decoration: underline;
}

.login-btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.login-btn.disabled {
  opacity: 0.5;
  background-color: #9CA3AF !important;
  color: #FFFFFF !important;
}

/* 法律文档弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 999;
}

.modal-content {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 85vw;
  max-width: 600rpx;
  max-height: 70vh;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  z-index: 1000;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #E5E7EB;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
}

.close-btn {
  font-size: 28rpx;
  color: #9CA3AF;
  cursor: pointer;
}

.modal-body {
  height: 400rpx;
  padding: 24rpx 32rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #374151;
  overflow-y: auto;
}

.modal-confirm {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #10B981 !important;
  color: white !important;
  border-radius: 0 0 16rpx 16rpx !important;
  font-size: 28rpx !important;
}