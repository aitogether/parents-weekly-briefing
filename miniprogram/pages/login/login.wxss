/* pages/login/login.wxss */
.container {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1F2937;
  display: block;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #6B7280;
}

.role-selection {
  display: flex;
  gap: 24rpx;
  margin-bottom: 60rpx;
}

.role-card {
  flex: 1;
  border: 2rpx solid #E5E7EB;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  text-align: center;
  background-color: #FFFFFF;
  transition: all 0.2s ease;
}

.role-card.selected {
  border-color: #10B981;
  background-color: #F0FAF6;
}

.role-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2937;
  margin-top: 16rpx;
  margin-bottom: 8rpx;
}

.role-desc {
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.4;
}

.privacy-section {
  display: flex;
  align-items: flex-start;
  margin-bottom: 40rpx;
  padding: 0 12rpx;
}

checkbox {
  margin-right: 12rpx;
  transform: scale(0.9);
}

.privacy-text {
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.6;
  flex: 1;
}

.link {
  color: #10B981;
  text-decoration: underline;
}

.login-btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.login-btn.disabled {
  opacity: 0.5;
  background-color: #9CA3AF !important;
  color: #FFFFFF !important;
}