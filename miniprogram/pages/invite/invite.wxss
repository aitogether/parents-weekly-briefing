/* pages/invite/invite.wxss */
.container {
  padding: 24rpx;
  background-color: #F9FAFB;
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 48rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1F2937;
  display: block;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #6B7280;
}

.invite-section {
  max-width: 600rpx;
  margin: 0 auto;
}

.code-card {
  background-color: white;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  text-align: center;
}

.label {
  font-size: 28rpx;
  color: #6B7280;
  display: block;
  margin-bottom: 16rpx;
}

.code-display {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.code {
  font-size: 36rpx;
  font-weight: bold;
  color: #10B981;
  letter-spacing: 4rpx;
  padding: 12rpx 24rpx;
  background-color: #F0FAF6;
  border-radius: 8rpx;
}

.copy-btn {
  background-color: #10B981 !important;
  color: white !important;
  border-radius: 20rpx !important;
  font-size: 24rpx !important;
}

.qr-section {
  background-color: white;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  text-align: center;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 24rpx;
  display: block;
}

.qr-container {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.qr-container image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 16rpx;
}

.qr-desc {
  font-size: 24rpx;
  color: #6B7280;
}

.share-section {
  text-align: center;
}

.share-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #0EA5E9 !important;
  color: white !important;
  border-radius: 44rpx !important;
  font-size: 32rpx !important;
  font-weight: 600;
  margin-bottom: 32rpx;
}

.share-tips {
  background-color: white;
  border-radius: 16rpx;
  padding: 32rpx;
}

.tip-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
  display: block;
  margin-bottom: 16rpx;
}

.tip-item {
  font-size: 26rpx;
  color: #6B7280;
  display: block;
  margin-bottom: 8rpx;
  text-align: left;
}

/* 验证页面样式 */
.verification-section {
  max-width: 600rpx;
  margin: 0 auto;
}

.loading-state,
.success-state,
.error-state {
  text-align: center;
  padding: 60rpx 24rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #6B7280;
}

.success-state image,
.error-state image {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 32rpx;
}

.info-card {
  background-color: white;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
}

.info-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1F2937;
  display: block;
  margin-bottom: 16rpx;
}

.info-desc {
  font-size: 26rpx;
  color: #6B7280;
  display: block;
  margin-bottom: 8rpx;
}

.confirm-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #10B981 !important;
  color: white !important;
  border-radius: 44rpx !important;
  font-size: 32rpx !important;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.cancel-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #F3F4F6 !important;
  color: #6B7280 !important;
  border-radius: 44rpx !important;
  font-size: 32rpx !important;
}

.error-text {
  font-size: 28rpx;
  color: #EF4444;
  margin-bottom: 32rpx;
  display: block;
}

.retry-btn {
  width: 200rpx;
  height: 60rpx;
  line-height: 60rpx;
  background-color: #6B7280 !important;
  color: white !important;
  border-radius: 30rpx !important;
  font-size: 28rpx !important;
}