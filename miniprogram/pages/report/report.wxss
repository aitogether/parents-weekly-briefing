/* ============================================
   子女端周报首屏
   色板来源：../../styles/colors.wxss
   ============================================ */

/* --- 全局 & 页面容器 --- */

.page-container {
  min-height: 100vh;
  background-color: var(--echo-bg);
  padding: 24rpx 32rpx 48rpx;
  box-sizing: border-box;
}

/* --- 通用卡片 --- */

.card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
  border: 1px solid var(--card-border);
}

/* --- 顶部状态卡 --- */

.status-card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 40rpx 36rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 1px 6px rgba(0, 0, 0, 0.05);
  border: 1px solid var(--card-border);
}

.status-header {
  margin-bottom: 28rpx;
}

.status-title {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text-main);
  line-height: 1.4;
}

.status-date {
  font-size: 28rpx;
  color: var(--text-sub);
  margin-top: 8rpx;
  line-height: 1.5;
}

.status-light-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.status-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
}

/* 绿灯 / 正常 */
.status-dot--green {
  background-color: var(--brand-teal);
  box-shadow: 0 0 8rpx rgba(32, 160, 128, 0.4);
}

/* 黄灯 */
.status-dot--yellow {
  background-color: #F09933;
  box-shadow: 0 0 8rpx rgba(240, 153, 51, 0.4);
}

/* 红灯 / 警告 */
.status-dot--red {
  background-color: var(--heart-red);
  box-shadow: 0 0 8rpx rgba(232, 64, 64, 0.4);
}

.status-label {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--brand-teal);
  letter-spacing: 1rpx;
}

/* --- 一句话总结卡 --- */

.summary-card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
  border: 1px solid var(--card-border);
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.summary-icon {
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background-color: var(--brand-teal-light);
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-text {
  font-size: 28rpx;
}

.summary-text {
  font-size: 30rpx;
  color: var(--text-main);
  line-height: 1.7;
  flex: 1;
}

/* --- 关键事实卡 --- */

.fact-card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
  border: 1px solid var(--card-border);
}

.fact-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.fact-label {
  font-size: 28rpx;
  color: var(--text-sub);
  line-height: 1.5;
}

.fact-value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-main);
}

.fact-value--warn {
  color: #F09933;
}

.fact-bar-track {
  height: 12rpx;
  border-radius: 6rpx;
  background-color: var(--brand-teal-light);
  overflow: hidden;
  margin-bottom: 14rpx;
}

.fact-bar-fill {
  height: 100%;
  border-radius: 6rpx;
  background-color: var(--brand-teal);
  transition: width 0.6s ease;
}

.fact-sub {
  font-size: 26rpx;
  color: var(--text-sub);
  line-height: 1.5;
}

/* --- 回声区 --- */

.echo-section {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  margin-top: 8rpx;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
  border: 1px solid var(--card-border);
}

.echo-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 10rpx;
}

.echo-subtitle {
  font-size: 26rpx;
  color: var(--text-sub);
  margin-bottom: 28rpx;
  line-height: 1.5;
}

.echo-btn-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.echo-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-main);
  background-color: #FFFFFF;
  border: 1.5px solid var(--card-border);
  transition: all 0.2s ease;
}

.echo-btn--active {
  background-color: var(--brand-teal);
  border-color: var(--brand-teal);
  color: #FFFFFF;
}

.echo-submit {
  width: 100%;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  background-color: var(--brand-teal);
  transition: all 0.2s ease;
}

.echo-submit--disabled {
  background-color: #BDBDBD;
  opacity: 0.5;
}

/* ── 情绪记录卡片 ── */

.emotion-card {
  background: linear-gradient(135deg, #FFF9F0 0%, #FFFFFF 100%);
  border: 2rpx solid #FFE8CC;
}

.emotion-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.emotion-icon {
  font-size: 48rpx;
  line-height: 1;
}

.emotion-title-group {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.emotion-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
}

.emotion-desc {
  font-size: 26rpx;
  color: #999;
  line-height: 1.4;
}

.emotion-options {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.emoji-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx 8rpx;
  border-radius: 20rpx;
  background-color: #F8F8F8;
  border: 3rpx solid transparent;
  transition: all 0.2s ease;
}

.emoji-btn.selected {
  background-color: #FFF3E0;
  border-color: #FFB74D;
  transform: scale(1.05);
}

.emoji-btn .emoji {
  font-size: 56rpx;
  line-height: 1;
  margin-bottom: 8rpx;
}

.emoji-btn .emoji-label {
  font-size: 24rpx;
  color: #666;
  line-height: 1.2;
}

.emoji-btn.selected .emoji-label {
  color: #F57C00;
  font-weight: 600;
}

.submit-emotion-btn {
  width: 100%;
  background: linear-gradient(135deg, #FFB74D 0%, #FF9800 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  padding: 24rpx 0;
  border: none;
}

.submit-emotion-btn[disabled] {
  background: #E0E0E0;
  color: #BDBDBD;
}

.submit-emotion-btn::after {
  border: none;
}

/* ── 已记录状态展示 ── */

.emotion-recorded {
  background: linear-gradient(135deg, #E8F5E9 0%, #FFFFFF 100%);
  border: 2rpx solid #C8E6C9;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.recorded-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.recorded-icon {
  font-size: 40rpx;
  line-height: 1;
}

.recorded-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2E7D32;
}

.recorded-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx 0;
}

.recorded-emoji {
  font-size: 64rpx;
  line-height: 1;
}

.recorded-level {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.recorded-week {
  font-size: 26rpx;
  color: #999;
  margin-left: auto;
}

/* ── 周报情绪分析 ── */

.emotion-summary {
  background: #FFFFFF;
  border-left: 6rpx solid #2196F3;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.summary-row:last-child {
  border-bottom: none;
}

.summary-label {
  font-size: 28rpx;
  color: #666;
}

.summary-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.summary-value.trend-improving {
  color: #4CAF50;
}

.summary-value.trend-stable {
  color: #2196F3;
}

.summary-value.trend-declining {
  color: #FF9800;
}

.alert-banner {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 16rpx;
  padding: 20rpx;
  background-color: #FFF3E0;
  border-radius: 12rpx;
  border: 2rpx solid #FFB74D;
}

.alert-icon {
  font-size: 36rpx;
  line-height: 1;
}

.alert-text {
  flex: 1;
  font-size: 28rpx;
  color: #E65100;
  font-weight: 500;
  line-height: 1.5;
}
