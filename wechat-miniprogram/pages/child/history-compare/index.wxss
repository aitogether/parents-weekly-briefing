/* pages/child/history-compare/index.wxss — 多周趋势对比 P2-4 */

.compare-page {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 32rpx;
}

.page-header { margin-bottom: 32rpx; }
.page-title { font-size: 40rpx; font-weight: 700; color: #222; display: block; }
.page-desc { font-size: 26rpx; color: #999; }

/* 每个父母的趋势 */
.timeline {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.parent-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

/* 灯号点 */
.level-dots {
  display: flex;
  justify-content: space-around;
  margin-bottom: 16rpx;
}

.week-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.level-dot {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.level-dot.green { background: #E5F6F7; border: 3rpx solid #188068; }
.level-dot.yellow { background: #FFF8E5; border: 3rpx solid #F6B25C; }
.level-dot.red { background: #FDE8E8; border: 3rpx solid #E74C3C; }

.dot-label { font-size: 24rpx; font-weight: 700; }
.level-dot.green .dot-label { color: #188068; }
.level-dot.yellow .dot-label { color: #D4941A; }
.level-dot.red .dot-label { color: #E74C3C; }

.week-label { font-size: 20rpx; color: #bbb; }

/* 趋势总结 */
.trend-summary {
  padding: 16rpx 0;
  border-top: 1rpx solid #f0f0f0;
  margin-bottom: 12rpx;
}

.trend-item {
  font-size: 26rpx;
  color: #555;
  display: block;
  margin-bottom: 4rpx;
}

/* 统计 */
.stats-row {
  display: flex;
  justify-content: space-around;
}

.stat { text-align: center; }

.stat-num {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
}

.green-stat .stat-num { color: #188068; }
.yellow-stat .stat-num { color: #D4941A; }
.red-stat .stat-num { color: #E74C3C; }

.stat-label {
  font-size: 22rpx;
  color: #999;
}

/* 返回 */
.back-link {
  text-align: center;
  padding: 16rpx 0;
}

.back-text {
  font-size: 26rpx;
  color: #188068;
}
