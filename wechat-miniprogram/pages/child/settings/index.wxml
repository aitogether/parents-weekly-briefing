<!-- pages/child/settings/index.wxml -->
<view class="container">
  <view class="card">
    <view class="card-title">通知设置</view>

    <view class="setting-item flex-between">
      <view class="setting-label">每日小结通知</view>
      <switch checked="{{dailySummaryEnabled}}" bindchange="onToggleDailySummary" color="#4CAF50"/>
    </view>

    <view class="setting-desc text-gray">
      每天中午 12:15 推送当日小结（绿灯/黄灯极简文案）
    </view>
  </view>

  <view class="card">
    <view class="setting-item flex-between">
      <view class="setting-label">周报推送通知</view>
      <switch checked="{{weeklyReportEnabled}}" bindchange="onToggleWeeklyReport" color="#4CAF50"/>
    </view>

    <view class="setting-desc text-gray">
      每周五 17:00 推送本周周报
    </view>
  </view>

  <view class="card">
    <view class="card-title">关于</view>
    <view class="about-item flex-between">
      <text>版本</text>
      <text class="text-gray">v1.0.0</text>
    </view>
    <view class="about-item flex-between">
      <text>隐私政策</text>
      <text class="text-gray" bindtap="onViewPrivacy">查看</text>
    </view>
  </view>

  <!-- 医疗免责声明 -->
  <view class="disclaimer-footer">
    本产品不提供医疗诊断、治疗建议，紧急情况请拨打120。
  </view>
</view>
