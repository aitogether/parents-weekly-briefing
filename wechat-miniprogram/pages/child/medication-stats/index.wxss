/* pages/child/medication-stats/index.wxss */

.progress-section {
  margin: 16rpx 0;
}

.progress-bar-bg {
  width: 100%;
  height: 24rpx;
  background: #e0e0e0;
  border-radius: 12rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  border-radius: 12rpx;
  transition: width 0.6s ease;
}

.progress-text {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #666;
}

.missed-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.missed-item:last-child {
  border-bottom: none;
}

.missed-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #F44336;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.missed-med {
  font-size: 28rpx;
  font-weight: 500;
}

.missed-time {
  font-size: 24rpx;
  margin-top: 4rpx;
}
