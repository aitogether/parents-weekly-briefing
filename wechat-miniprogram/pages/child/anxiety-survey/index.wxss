/* pages/child/anxiety-survey/index.wxss — 焦虑感自报量表 P1-7 */

.survey-page {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 32rpx;
}

.page-header { margin-bottom: 40rpx; }
.page-title { font-size: 40rpx; font-weight: 700; color: #222; display: block; margin-bottom: 8rpx; }
.page-desc { font-size: 26rpx; color: #999; }

/* 问题卡片 */
.question-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.q-index {
  font-size: 24rpx;
  color: #188068;
  font-weight: 700;
  display: block;
  margin-bottom: 8rpx;
}

.q-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  display: block;
  margin-bottom: 20rpx;
  line-height: 1.5;
}

/* 刻度 */
.scale-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.scale-label {
  font-size: 20rpx;
  color: #999;
  flex-shrink: 0;
  width: 100rpx;
  text-align: center;
}

.scale-dots {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.scale-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 2rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #999;
  transition: all 0.15s;
}

.scale-dot.active {
  background: #188068;
  border-color: #188068;
  color: #fff;
  font-weight: 700;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 16rpx;
  background: #188068;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  margin-top: 20rpx;
}

.submit-btn[disabled] {
  background: #ccc;
  opacity: 0.6;
}

.submit-btn::after { border: none; }

/* 结果 */
.result-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.result-score {
  font-size: 72rpx;
  font-weight: 800;
  color: #188068;
  display: block;
  margin-bottom: 16rpx;
}

.result-msg {
  font-size: 30rpx;
  color: #555;
  display: block;
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.done-btn {
  width: 60%;
  height: 80rpx;
  border-radius: 12rpx;
  background: #E5F6F7;
  color: #188068;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.done-btn::after { border: none; }
