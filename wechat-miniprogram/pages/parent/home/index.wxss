/* pages/parent/home/index.wxss — 父母端首页 v0.2（一键确认） */
.parent-home {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 32rpx;
}

/* ── 头部 ── */
.header {
  margin-bottom: 32rpx;
}

.date {
  font-size: 28rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.greeting {
  font-size: 44rpx;
  font-weight: 700;
  color: #222;
}

/* ── 邀请码卡片 ── */
.invite-card {
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  text-align: center;
}

.invite-label {
  font-size: 30rpx;
  color: #2E7D32;
  margin-bottom: 16rpx;
}

.invite-code {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.code-char {
  width: 64rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: #fff;
  border-radius: 12rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #2E7D32;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}

.invite-hint {
  font-size: 28rpx;
  color: #66BB6A;
}

/* ── 今日步数 ── */
.steps-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 32rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.steps-label {
  font-size: 30rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.steps-value {
  font-size: 80rpx;
  font-weight: 800;
  color: #188068;
  display: block;
}

.steps-unit {
  font-size: 28rpx;
  color: #666;
}

/* ── 一键确认按钮 ── */
.confirm-section {
  margin-bottom: 32rpx;
  text-align: center;
}

.one-btn {
  width: 100%;
  height: 140rpx;
  border-radius: 20rpx;
  background: #188068;
  color: #fff;
  font-size: 40rpx;
  font-weight: 700;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(24,128,104,0.3);
}

.one-btn::after {
  border: none;
}

.one-btn:active {
  transform: scale(0.98);
}

.one-btn.confirmed {
  background: #E0E0E0;
  color: #999;
  box-shadow: none;
}

.one-btn-text {
  font-size: 40rpx;
  font-weight: 700;
}

.confirm-feedback {
  margin-top: 20rpx;
}

.feedback-heart {
  font-size: 28rpx;
  color: #E84040;
}

/* ── 本周统计 ── */
.week-stats {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.stat-item {
  font-size: 28rpx;
  color: #555;
  display: block;
  line-height: 2;
}

.stat-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.stat-link {
  font-size: 30rpx;
  color: #188068;
  font-weight: 600;
}

/* ── 扫码帮手入口 ── */
.scan-shortcut.card {
  background: linear-gradient(135deg, #E3F2FD, #BBDEFB);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(33, 150, 243, 0.12);
}

.scan-icon {
  font-size: 64rpx;
  width: 96rpx;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.scan-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.scan-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1976D2;
}

.scan-subtitle {
  font-size: 28rpx;
  color: #5E92F3;
  line-height: 1.4;
}

.scan-arrow {
  font-size: 48rpx;
  color: #1976D2;
  font-weight: 300;
}

/* ── 叫车帮手入口 ── */
.taxi-shortcut.card {
  background: linear-gradient(135deg, #FFF3E0, #FFE0B2);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 152, 0, 0.12);
}

.taxi-icon {
  font-size: 64rpx;
  width: 96rpx;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.taxi-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.taxi-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #E65100;
}

.taxi-subtitle {
  font-size: 28rpx;
  color: #F57C00;
  line-height: 1.4;
}

.taxi-arrow {
  font-size: 48rpx;
  color: #E65100;
  font-weight: 300;
}

/* ── 回声 ── */
.echo-card {
  background: #FFF8E1;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 32rpx;
}

.echo-label {
  font-size: 28rpx;
  color: #F57F17;
  display: block;
  margin-bottom: 8rpx;
}

.echo-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

/* ── 重置按钮 ── */
.reset-btn {
  margin-top: 24rpx;
  background: transparent;
  border: 2rpx dashed #ccc;
  color: #999;
  font-size: 28rpx;
  border-radius: 12rpx;
}

.reset-btn::after {
  border: none;
}

/* ── 用药确认 ActionSheet ── */
.action-sheet-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 100;
}

.action-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  z-index: 101;
  padding-bottom: env(safe-area-inset-bottom);
}

.sheet-title {
  text-align: center;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #eee;
}

.sheet-btn {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  background: #F5F5F5;
}

.sheet-btn.taken {
  color: #188068;
  background: #E8F5E9;
}

.sheet-btn.missed {
  color: #E65100;
  background: #FFF3E0;
}

.sheet-cancel {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
  color: #999;
  margin-top: 8rpx;
}


/* ── 医疗免责声明横幅（父母端） ── */
.disclaimer-footer {
  margin-top: 40rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, #E3F2FD 0%, #FFFFFF 100%);
  border: 3rpx solid #BBDEFB;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #1565C0;
  line-height: 1.7;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(21, 101, 192, 0.08);
}


/* ── 用药进度条 ── */
.med-progress-section {
  margin-top: 24rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #E8F5E9 0%, #FFFFFF 100%);
  border-radius: 16rpx;
  border: 2rpx solid #C8E6C9;
}

.med-progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.med-progress-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #2E7D32;
}

.med-progress-percent {
  font-size: 36rpx;
  font-weight: 700;
  color: #2E7D32;
}

.med-progress-bar {
  width: 100%;
  height: 20rpx;
  background-color: #E8F5E9;
  border-radius: 10rpx;
  overflow: hidden;
}

.med-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4CAF50 0%, #8BC34A 100%);
  border-radius: 10rpx;
  transition: width 0.3s ease;
}
