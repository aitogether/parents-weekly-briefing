/* pages/parent/home/index.wxss */
.parent-home {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 32rpx;
}

/* ── 头部 ── */
.header {
  margin-bottom: 32rpx;
}

.date {
  font-size: 28rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.greeting {
  font-size: 44rpx;
  font-weight: 700;
  color: #222;
}

/* ── 邀请码卡片 ── */
.invite-card {
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  text-align: center;
}

.invite-label {
  font-size: 26rpx;
  color: #2E7D32;
  margin-bottom: 16rpx;
}

.invite-code {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.code-char {
  width: 64rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: #fff;
  border-radius: 12rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #2E7D32;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}

.invite-hint {
  font-size: 22rpx;
  color: #66BB6A;
}

/* ── 确认区域 ── */
.confirm-section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
  display: block;
  margin-bottom: 20rpx;
}

.done-title {
  color: #4CAF50;
}

.confirm-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.confirm-q {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.confirm-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.confirm-label {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

/* ── 大按钮 ── */
.btn-row {
  display: flex;
  gap: 20rpx;
}

.big-btn {
  flex: 1;
  height: 120rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
}

.big-btn::after {
  border: none;
}

.big-btn.done {
  background: #E8F5E9;
}

.big-btn.done .btn-emoji {
  font-size: 36rpx;
}

.big-btn.done .btn-text {
  font-size: 28rpx;
  color: #2E7D32;
  font-weight: 600;
  margin-top: 4rpx;
}

.big-btn.skip {
  background: #FFF3E0;
}

.big-btn.skip .btn-emoji {
  font-size: 36rpx;
}

.big-btn.skip .btn-text {
  font-size: 28rpx;
  color: #E65100;
  font-weight: 600;
  margin-top: 4rpx;
}

/* ── 已确认 ── */
.confirmed {
  text-align: center;
  padding: 16rpx 0;
}

.confirmed-text {
  font-size: 30rpx;
  font-weight: 500;
}

.confirmed-text.done {
  color: #4CAF50;
}

.confirmed-text.skip {
  color: #FF9800;
}

/* ── 回声 ── */
.echo-card {
  background: #FFF8E1;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 32rpx;
}

.echo-label {
  font-size: 24rpx;
  color: #F57F17;
  display: block;
  margin-bottom: 8rpx;
}

.echo-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

/* ── 完成卡片 ── */
.done-card {
  background: linear-gradient(135deg, #E8F5E9, #A5D6A7);
  border-radius: 20rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  margin-bottom: 32rpx;
}

.done-emoji {
  font-size: 64rpx;
  display: block;
  margin-bottom: 16rpx;
}

.done-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #2E7D32;
  display: block;
  margin-bottom: 8rpx;
}

.done-sub {
  font-size: 26rpx;
  color: #66BB6A;
}

/* ── 重置按钮 ── */
.reset-btn {
  margin-top: 24rpx;
  background: transparent;
  border: 2rpx dashed #ccc;
  color: #999;
  font-size: 24rpx;
  border-radius: 12rpx;
}

.reset-btn::after {
  border: none;
}
