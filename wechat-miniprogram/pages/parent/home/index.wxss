/* pages/parent/home/index.wxss — 父母端首页 v0.2（一键确认） */
.parent-home {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 32rpx;
}

/* ── 头部 ── */
.header {
  margin-bottom: 32rpx;
}

.date {
  font-size: 28rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.greeting {
  font-size: 44rpx;
  font-weight: 700;
  color: #222;
}

/* ── 邀请码卡片 ── */
.invite-card {
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  text-align: center;
}

.invite-label {
  font-size: 26rpx;
  color: #2E7D32;
  margin-bottom: 16rpx;
}

.invite-code {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.code-char {
  width: 64rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: #fff;
  border-radius: 12rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #2E7D32;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}

.invite-hint {
  font-size: 22rpx;
  color: #66BB6A;
}

/* ── 今日步数 ── */
.steps-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 32rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.steps-label {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.steps-value {
  font-size: 80rpx;
  font-weight: 800;
  color: #188068;
  display: block;
}

.steps-unit {
  font-size: 28rpx;
  color: #666;
}

/* ── 一键确认按钮 ── */
.confirm-section {
  margin-bottom: 32rpx;
  text-align: center;
}

.one-btn {
  width: 100%;
  height: 140rpx;
  border-radius: 20rpx;
  background: #188068;
  color: #fff;
  font-size: 40rpx;
  font-weight: 700;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(24,128,104,0.3);
}

.one-btn::after {
  border: none;
}

.one-btn:active {
  transform: scale(0.98);
}

.one-btn.confirmed {
  background: #E0E0E0;
  color: #999;
  box-shadow: none;
}

.one-btn-text {
  font-size: 40rpx;
  font-weight: 700;
}

.confirm-feedback {
  margin-top: 20rpx;
}

.feedback-heart {
  font-size: 28rpx;
  color: #E84040;
}

/* ── 本周统计 ── */
.week-stats {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.stat-item {
  font-size: 28rpx;
  color: #555;
  display: block;
  line-height: 2;
}

.stat-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.stat-link {
  font-size: 26rpx;
  color: #188068;
  font-weight: 600;
}

/* ── 回声 ── */
.echo-card {
  background: #FFF8E1;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 32rpx;
}

.echo-label {
  font-size: 24rpx;
  color: #F57F17;
  display: block;
  margin-bottom: 8rpx;
}

.echo-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

/* ── 重置按钮 ── */
.reset-btn {
  margin-top: 24rpx;
  background: transparent;
  border: 2rpx dashed #ccc;
  color: #999;
  font-size: 24rpx;
  border-radius: 12rpx;
}

.reset-btn::after {
  border: none;
}

/* ── 用药确认 ActionSheet ── */
.action-sheet-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 100;
}

.action-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  z-index: 101;
  padding-bottom: env(safe-area-inset-bottom);
}

.sheet-title {
  text-align: center;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #eee;
}

.sheet-btn {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  background: #F5F5F5;
}

.sheet-btn.taken {
  color: #188068;
  background: #E8F5E9;
}

.sheet-btn.missed {
  color: #E65100;
  background: #FFF3E0;
}

.sheet-cancel {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
  color: #999;
  margin-top: 8rpx;
}
