/* pages/parent/med-reminder/index.wxss — 用药提醒设置 v0.2 */

.reminder-page {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 32rpx;
}

/* ── 头部 ── */
.page-header {
  margin-bottom: 40rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #222;
  display: block;
  margin-bottom: 8rpx;
}

.page-desc {
  font-size: 26rpx;
  color: #999;
}

/* ── 时间列表 ── */
.time-list {
  margin-bottom: 24rpx;
}

.time-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.time-info {
  flex: 1;
}

.time-value {
  font-size: 48rpx;
  font-weight: 800;
  color: #188068;
  display: block;
}

.time-note {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}

.time-delete {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #FFECEC;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  font-size: 28rpx;
  color: #E84040;
}

/* ── 添加按钮 ── */
.add-btn {
  width: 100%;
  height: 96rpx;
  border: 2rpx dashed #188068;
  border-radius: 16rpx;
  background: transparent;
  color: #188068;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-bottom: 40rpx;
}

.add-btn::after { border: none; }

.add-icon {
  font-size: 36rpx;
  font-weight: 700;
}

/* ── 保存按钮 ── */
.save-btn {
  width: 100%;
  height: 100rpx;
  border-radius: 16rpx;
  background: #188068;
  color: #fff;
  font-size: 34rpx;
  font-weight: 700;
  border: none;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 20rpx rgba(24,128,104,0.3);
}

.save-btn::after { border: none; }

/* ── 说明 ── */
.tips {
  padding: 0 8rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #999;
  display: block;
  line-height: 2;
}

/* ── 时间选择器 ── */
.picker-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 100;
}

.picker-panel {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  z-index: 101;
  padding-bottom: env(safe-area-inset-bottom);
}

.picker-header {
  text-align: center;
  margin-bottom: 24rpx;
}

.picker-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.time-picker {
  width: 100%;
  height: 300rpx;
}

.picker-item {
  line-height: 50px;
  text-align: center;
  font-size: 32rpx;
}

.picker-confirm {
  width: 100%;
  height: 88rpx;
  border-radius: 16rpx;
  background: #188068;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  margin-top: 24rpx;
}

.picker-confirm::after { border: none; }
