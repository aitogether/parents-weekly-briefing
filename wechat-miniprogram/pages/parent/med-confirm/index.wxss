/* pages/parent/med-confirm/index.wxss */
/* UI 规范 v1 · 老人端：大字体、大按钮 */

page {
  background: #F5F5F7;
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
}

.page-header {
  padding: 20px;
  text-align: center;
}
.page-date {
  font-size: 32rpx;
  color: #0F5960;
  font-weight: 600;
}

.card {
  background: #fff;
  border-radius: 12px;
  padding: 24px 20px;
  margin: 0 16px 16px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
}

.med-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #0F5960;
  margin-bottom: 4px;
}
.med-schedule {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20px;
}

/* 大按钮 */
.med-btn-row {
  display: flex;
  gap: 12px;
}
.med-btn {
  flex: 1;
  padding: 22px 0;
  border: none;
  border-radius: 12px;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1;
}
.med-btn.taken {
  background: #22A060;
  color: #fff;
}
.med-btn.not-taken {
  background: #fff;
  color: #D6453D;
  border: 2px solid #D6453D;
}

/* 已确认状态 */
.med-confirmed {
  text-align: center;
  padding: 16px 0 4px;
}
.med-confirmed-text {
  font-size: 32rpx;
  font-weight: 600;
}
.med-confirmed-text.taken { color: #22A060; }
.med-confirmed-text.skipped { color: #D6453D; }

/* 回声卡片 */
.elder-echo {
  background: #E5F6F7;
  border-radius: 12px;
  padding: 20px;
  margin: 20px 16px;
}
.elder-echo-title {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 10px;
}
.elder-echo-text {
  font-size: 32rpx;
  color: #0F5960;
  line-height: 1.6;
  font-weight: 500;
}
