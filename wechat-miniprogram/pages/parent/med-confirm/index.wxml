<!-- pages/parent/med-confirm/index.wxml -->
<view class="page">
  <view class="page-header">
    <text class="page-date">{{today}}</text>
  </view>

  <!-- 用药卡片 -->
  <view class="card" wx:for="{{plans}}" wx:key="id">
    <view class="med-name">{{item.nickname}} · {{item.dosage}}</view>
    <view class="med-schedule">{{item.schedule}}</view>
    <view class="med-btn-row" wx:if="{{!item.confirmed}}">
      <button class="med-btn taken" bindtap="onConfirm" data-id="{{item.id}}" data-status="taken">✅ 已吃</button>
      <button class="med-btn not-taken" bindtap="onConfirm" data-id="{{item.id}}" data-status="skipped">没吃</button>
    </view>
    <view class="med-confirmed" wx:else>
      <text class="med-confirmed-text {{item.status}}">{{item.status === 'taken' ? '✅ 已确认吃过' : '❌ 已跳过'}}</text>
    </view>
  </view>

  <!-- 老人端回声卡片（7天内有反馈才显示） -->
  <view class="elder-echo" wx:if="{{echoText}}">
    <view class="elder-echo-title">💬 来自家里人的一句话</view>
    <view class="elder-echo-text">{{echoText}}</view>
  </view>

  <!-- 医疗免责声明 -->
  <view class="disclaimer-footer">
    本产品不提供医疗诊断、治疗建议，紧急情况请拨打120。
  </view>
</view>
