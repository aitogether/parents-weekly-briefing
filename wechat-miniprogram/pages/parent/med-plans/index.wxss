/* pages/parent/med-plans/index.wxss */

.plan-item {
  padding: 8rpx 0;
}

.plan-header {
  margin-bottom: 16rpx;
}

.plan-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
}

.plan-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
}

.status-done {
  background: #e8f5e9;
  color: #4CAF50;
}

.status-pending {
  background: #fff8e1;
  color: #FFA000;
}

.plan-row {
  font-size: 28rpx;
  margin-bottom: 8rpx;
  line-height: 1.6;
}

.plan-row:last-child {
  margin-bottom: 0;
}
