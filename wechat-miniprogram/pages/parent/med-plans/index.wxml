<!-- pages/parent/med-plans/index.wxml -->
<view class="container">
  <view class="card" wx:for="{{plans}}" wx:key="id">
    <view class="plan-item">
      <view class="plan-header flex-between">
        <view class="plan-name">{{item.medName}}</view>
        <view class="plan-status {{item.status === 'confirmed' ? 'status-done' : 'status-pending'}}">
          {{item.status === 'confirmed' ? '已确认' : '待确认'}}
        </view>
      </view>
      <view class="plan-detail">
        <view class="plan-row">
          <text class="text-gray">剂量：</text>
          <text>{{item.dosage}}</text>
        </view>
        <view class="plan-row">
          <text class="text-gray">时间：</text>
          <text>{{item.scheduledTime}}</text>
        </view>
        <view class="plan-row" wx:if="{{item.frequency}}">
          <text class="text-gray">频率：</text>
          <text>{{item.frequency}}</text>
        </view>
        <view class="plan-row" wx:if="{{item.remark}}">
          <text class="text-gray">备注：</text>
          <text>{{item.remark}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="card text-center" wx:if="{{loading}}">
    <view class="text-gray">加载中...</view>
  </view>

  <view class="card text-center" wx:if="{{!loading && plans.length === 0}}">
    <view class="text-gray">暂无用药计划</view>
  </view>

  <!-- 医疗免责声明 -->
  <view class="disclaimer-footer">
    本产品不提供医疗诊断、治疗建议或处方。所有健康信息仅供参考，不能替代专业医疗人员的诊断和建议。如有健康问题，请咨询医生或其他合格的医疗专业人士。
  </view>
</view>
