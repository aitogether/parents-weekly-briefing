.container {
  padding: 20rpx 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.level-indicator {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  display: inline-block;
  margin-right: 12rpx;
  vertical-align: middle;
}

.level-indicator.green { background-color: #07C160; }
.level-indicator.yellow { background-color: #FFC300; }
.level-indicator.red { background-color: #FA5151; }

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.section-desc {
  font-size: 28rpx;
  color: #666;
  display: block;
}

.section-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.parent-label {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.fact-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.fact-row:last-child {
  border-bottom: none;
}

.fact-label {
  font-size: 26rpx;
  color: #999;
  width: 160rpx;
}

.fact-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
}

.fact-note {
  font-size: 24rpx;
  color: #999;
}

.wonder-item {
  font-size: 26rpx;
  color: #666;
  display: block;
  padding: 8rpx 0;
  line-height: 1.6;
}

.feedback-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.feedback-btn {
  background-color: #07C160;
  color: #fff;
  font-size: 28rpx;
  border-radius: 12rpx;
}

.feedback-btn.secondary {
  background-color: #f0f0f0;
  color: #666;
}
