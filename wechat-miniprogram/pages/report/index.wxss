.container {
  padding: 20rpx 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.level-indicator {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  display: inline-block;
  margin-right: 12rpx;
  vertical-align: middle;
}

.level-indicator.green { background-color: #07C160; }
.level-indicator.yellow { background-color: #FFC300; }
.level-indicator.red { background-color: #FA5151; }

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.section-desc {
  font-size: 28rpx;
  color: #666;
  display: block;
}

.section-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.parent-label {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.fact-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.fact-row:last-child {
  border-bottom: none;
}

.fact-label {
  font-size: 26rpx;
  color: #999;
  width: 160rpx;
}

.fact-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
}

.fact-note {
  font-size: 24rpx;
  color: #999;
}

.wonder-item {
  font-size: 26rpx;
  color: #666;
  display: block;
  padding: 8rpx 0;
  line-height: 1.6;
}

.feedback-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.feedback-btn {
  background-color: #07C160;
  color: #fff;
  font-size: 28rpx;
  border-radius: 12rpx;
}

.feedback-btn.secondary {
  background-color: #f0f0f0;
  color: #666;
}

/* ── 情绪记录卡片 ── */

.emotion-card {
  background: linear-gradient(135deg, #FFF9F0 0%, #FFFFFF 100%);
  border: 2rpx solid #FFE8CC;
}

.emotion-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.emotion-icon {
  font-size: 48rpx;
  line-height: 1;
}

.emotion-title-group {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.emotion-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
}

.emotion-desc {
  font-size: 26rpx;
  color: #999;
  line-height: 1.4;
}

.emotion-options {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.emoji-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx 8rpx;
  border-radius: 20rpx;
  background-color: #F8F8F8;
  border: 3rpx solid transparent;
  transition: all 0.2s ease;
}

.emoji-btn.selected {
  background-color: #FFF3E0;
  border-color: #FFB74D;
  transform: scale(1.05);
}

.emoji-btn .emoji {
  font-size: 56rpx;
  line-height: 1;
  margin-bottom: 8rpx;
}

.emoji-btn .emoji-label {
  font-size: 24rpx;
  color: #666;
  line-height: 1.2;
}

.emoji-btn.selected .emoji-label {
  color: #F57C00;
  font-weight: 600;
}

.submit-emotion-btn {
  width: 100%;
  background: linear-gradient(135deg, #FFB74D 0%, #FF9800 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  padding: 24rpx 0;
  border: none;
}

.submit-emotion-btn[disabled] {
  background: #E0E0E0;
  color: #BDBDBD;
}

.submit-emotion-btn::after {
  border: none;
}

/* ── 已记录状态展示 ── */

.emotion-recorded {
  background: linear-gradient(135deg, #E8F5E9 0%, #FFFFFF 100%);
  border: 2rpx solid #C8E6C9;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.recorded-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.recorded-icon {
  font-size: 40rpx;
  line-height: 1;
}

.recorded-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2E7D32;
}

.recorded-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx 0;
}

.recorded-emoji {
  font-size: 64rpx;
  line-height: 1;
}

.recorded-level {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.recorded-week {
  font-size: 26rpx;
  color: #999;
  margin-left: auto;
}

/* ── 周报情绪分析 ── */

.emotion-summary {
  background: #FFFFFF;
  border-left: 6rpx solid #2196F3;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.summary-row:last-child {
  border-bottom: none;
}

.summary-label {
  font-size: 28rpx;
  color: #666;
}

.summary-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.summary-value.trend-improving {
  color: #4CAF50;
}

.summary-value.trend-stable {
  color: #2196F3;
}

.summary-value.trend-declining {
  color: #FF9800;
}

.alert-banner {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 16rpx;
  padding: 20rpx;
  background-color: #FFF3E0;
  border-radius: 12rpx;
  border: 2rpx solid #FFB74D;
}

.alert-icon {
  font-size: 36rpx;
  line-height: 1;
}

.alert-text {
  flex: 1;
  font-size: 28rpx;
  color: #E65100;
  font-weight: 500;
  line-height: 1.5;
}

